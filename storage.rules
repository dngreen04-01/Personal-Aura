rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Exercise media: any authenticated user can read
    match /exercises/{allPaths=**} {
      allow read: if request.auth != null;
    }

    // User avatars: owner can read/write, others can read
    match /avatars/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Social media: author can write, visibility handled at app level
    match /social/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
